# Copy this file to .env and fill in all values before running the dashboard.

# ── Database ──────────────────────────────────────────────────────────────────
# Single PostgreSQL database used for both dashboard auth tables and app data.
# Local dev:    postgres://postgres:admin@localhost:5432/zyber?sslmode=disable
# Cloud SQL:    postgres://<user>:<pass>@<HOST>:5432/zyber?sslmode=require
DATABASE_URL=postgres://postgres:admin@localhost:5432/zyber?sslmode=disable

# ── Better Auth ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=replace-with-a-strong-secret
# Full URL of this dashboard server (no trailing slash)
BETTER_AUTH_URL=http://localhost:3000

# ── Google OAuth (used for invitation-based team sign-up) ─────────────────────
# Create at https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: <BETTER_AUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Zyber backend ─────────────────────────────────────────────────────────────
# Base URL of the Go API server (no trailing slash)
ZYBER_API_URL=http://localhost:8080
# Super-admin credentials used to call privileged Zyber API endpoints
ZYBER_ADMIN_USERNAME=admin
ZYBER_ADMIN_PASSWORD=

# ── Maintainer sessions ───────────────────────────────────────────────────────
# Must match JWT_SECRET_ADMIN in the Go backend's .env exactly
JWT_SECRET_ADMIN=replace-with-the-backend-admin-jwt-secret

# ── Redis ─────────────────────────────────────────────────────────────────────
# Format: host:port  (matches Go backend REDIS_ADDR)
# Local dev: localhost:6379   |   Memorystore: <PRIVATE_IP>:6379
REDIS_ADDR=localhost:6379
# AUTH string — empty for local dev, required for Memorystore with AUTH enabled
REDIS_PASSWORD=
# Set to "true" for Memorystore with in-transit TLS enabled; empty otherwise
REDIS_TLS=

# ── Firebase Analytics (GA4 Data API) ─────────────────────────────────────────
# Numeric GA4 property ID (Admin → Property Details). Example: 123456789
GA4_PROPERTY_ID=
# Single-line JSON of the FCM service account (same one the Go backend uses).
# In the GA4 console (Admin → Property Access Management), grant this account
# the "Viewer" role on the property.
GOOGLE_SERVICE_ACCOUNT_JSON=
